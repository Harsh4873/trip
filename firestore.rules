rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /tripBoards/new-mexico-2026 {
      allow get: if true;
      allow list, delete: if false;

      allow create, update: if request.time < timestamp.date(2026, 9, 1)
        && request.resource.data.keys().hasAll([
          'checked',
          'customTodos',
          'clientUpdatedAt',
          'updatedAt',
          'version'
        ])
        && request.resource.data.keys().hasOnly([
          'checked',
          'customTodos',
          'clientUpdatedAt',
          'updatedAt',
          'version'
        ])
        && request.resource.data.checked is list
        && request.resource.data.checked.size() <= 200
        && request.resource.data.customTodos is list
        && request.resource.data.customTodos.size() <= 30
        && request.resource.data.clientUpdatedAt is int
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.version == 1;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
